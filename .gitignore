/*.md
!/CLAUDE.md
!/README.md
!/CHANGELOG.md
!/DEVELOPER_QUICKSTART.md
/*.txt
!/requirements.txt
/prompt-claude.sh

# Implementation plans (working docs)
.plans/
plans/

# AI prompts
prompts/

# Design mockups (binary assets)
mocks/

# Data files (batch imports, caches, logs)
# Schema examples in data/examples/ are tracked
data/*.json
data/*.log
data/.ingestion-cache/
data/.ingestion-history/
data/archive/
data/expansion/
